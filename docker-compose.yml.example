services:
  miniflux-to-kindle:
    build:
      context: /home/jac/miniflux-to-kindle
      dockerfile: Dockerfile
    env_file: .env
    restart: unless-stopped
    read_only: true
    tmpfs:
      - /tmp
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: 512m
