services:
  miniflux-to-kindle:
    build:
      # If your compose file lives outside the repo, set this to the repo path
      context: .
      dockerfile: Dockerfile
    env_file: .env
    restart: unless-stopped
    read_only: true
    tmpfs:
      - /tmp
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: 512m
