MINIFLUX_BASE_URL=http://localhost:8080
MINIFLUX_API_KEY=your-miniflux-api-key
MINIFLUX_FEED_IDS=55,12,7
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
KINDLE_EMAIL=you@kindle.com
DIGEST_HOUR=6
TIMEZONE=America/Chicago
# Send a digest immediately when the container starts (default true);
# set false to only send at the scheduled hour
RUN_ON_STARTUP=true
# Optional: healthchecks.io ping URL; pings /start, success, and /fail per cycle
#HEALTHCHECK_URL=https://hc-ping.com/your-check-uuid
